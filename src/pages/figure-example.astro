---
import Figure from "../components/Figure.astro";
import MinimalLayout from "../layouts/MinimalLayout.astro";
---
<MinimalLayout>
  <div class="figure-demo">
    <Figure
      caption="Figure 1"
      title="Monthly sales volumes grew in November 2024 follwing a fall in October"
      subtitle="Volume sales, seasonally adjusted, Great Britain, November 2021 to November 2024"
      source="Source: Monthly Business Survey, Retail Sales Inquiry from the Office for National Statistics"
      border={ false }
    >
      <div class="placeholder" slot="visualisation">This is where the figure content would go</div>
      <p class="small" slot="footnotes">Footnotes go here...</p>
      <p class="small" slot="downloads">Download links go here...</p>
    </Figure>

    <label>
      <input type="checkbox" class="toggle-border" checked />
      Toggle border
    </label>
  </div>
</MinimalLayout>

<script>
  document.querySelectorAll('.figure-demo').forEach((demo) => {
    const checkbox = demo.querySelector<HTMLInputElement>('.toggle-border');
    const figure = demo.querySelector<HTMLElement>('figure');

    if (!checkbox || !figure) return;

    checkbox.checked = figure.classList.contains('figure-border');

    checkbox.addEventListener('change', () => {
      figure.classList.toggle('figure-border', checkbox.checked);
    });
  });
</script>

<style>
  .placeholder {
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    border: 1px dashed var(--color-border-primary);
  }

  .figure-demo {
    padding: var(--spacing-lg);
  }
</style>