---
const { sections = [] } = Astro.props;
---

<nav class="table-of-contents">
  <h2>Contents</h2>

  <ul>
    { sections.map((h) => (
      <li><a href={`#${h.slug}`}>{ h.text }</a></li>
    ))}
  </ul>

</nav>

<style>
  .table-of-contents {
    position: sticky;
    top: var(--spacing-md);
  }

  ul {
    list-style-type: "—";
    padding: 0;
    margin: 0;
  }

  ul li {
    margin: 0 0 var(--spacing-2xs) 0;
  }
</style>